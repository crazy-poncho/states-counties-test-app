# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=states_counties
POSTGRES_PORT=5432

# Backend
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/states_counties?schema=public
# Fallback only when a request has no Host (detail links normally use the request origin)
BASE_URL=http://localhost:3000

# Frontend (Nginx in Docker Compose)
FRONTEND_PORT=8080